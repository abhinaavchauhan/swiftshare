<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".ui.transfer.TransferFragment">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/transferring"
        app:titleTextColor="?colorOnSurface" />

    <!-- Main Content Card (Active State) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_active_transfer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/padding_screen"
        app:cardCornerRadius="@dimen/corner_xlarge"
        app:cardElevation="@dimen/elevation_low"
        app:layout_constraintBottom_toTopOf="@id/btn_cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/padding_screen">

            <!-- Circular Progress -->
            <FrameLayout
                android:id="@+id/progress_container"
                android:layout_width="@dimen/progress_size"
                android:layout_height="@dimen/progress_size">

                <!-- Background Circle -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_background"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:progress="100"
                    app:indicatorColor="@color/surface_container"
                    app:indicatorSize="180dp"
                    app:trackThickness="10dp" />

                <!-- Progress Indicator -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_transfer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    app:indicatorColor="?colorPrimary"
                    app:indicatorSize="180dp"
                    app:trackThickness="10dp"
                    app:trackColor="@android:color/transparent"
                    tools:progress="65" />

                <!-- Progress Content -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/text_progress_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorPrimary"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        tools:text="65%" />

                    <TextView
                        android:id="@+id/text_transfer_speed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.SwiftShare.Caption"
                        android:textColor="?colorOnSurfaceVariant"
                        tools:text="2.5 MB/s" />
                </LinearLayout>
            </FrameLayout>

            <!-- File Info -->
            <TextView
                android:id="@+id/text_file_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:ellipsize="middle"
                android:gravity="center"
                android:maxLines="2"
                android:textAppearance="@style/TextAppearance.SwiftShare.Title"
                android:textColor="?colorOnSurface"
                tools:text="high_quality_video_file.mp4" />

            <TextView
                android:id="@+id/text_transfer_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textAppearance="@style/TextAppearance.SwiftShare.Body"
                android:textColor="?colorOnSurfaceVariant"
                tools:text="Receiving from Galaxy S24…" />

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Size"
                        android:textAppearance="@style/TextAppearance.SwiftShare.Caption" />

                    <TextView
                        android:id="@+id/text_file_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorOnSurface"
                        android:textStyle="bold"
                        tools:text="12.5 MB" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:background="@color/divider" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ETA"
                        android:textAppearance="@style/TextAppearance.SwiftShare.Caption" />

                    <TextView
                        android:id="@+id/text_eta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorOnSurface"
                        android:textStyle="bold"
                        tools:text="0:45" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Success Container (hidden by default) -->
    <LinearLayout
        android:id="@+id/layout_success_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/padding_screen"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layout_completion_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/success" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="File Received Successfully!"
            android:textAppearance="@style/TextAppearance.SwiftShare.Headline"
            android:textColor="@color/success" />

        <TextView
            android:id="@+id/text_success_path"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_xl"
            android:text="Saved in Downloads/SwiftShare"
            android:textAppearance="@style/TextAppearance.SwiftShare.Body" />
        
    </LinearLayout>

    <!-- Buttons Container -->
    <LinearLayout
        android:id="@+id/layout_completion_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_screen"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_file"
            style="@style/Widget.SwiftShare.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="View File"
            app:icon="@drawable/ic_file" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_done"
            style="@style/Widget.SwiftShare.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Done" />
    </LinearLayout>

    <!-- Cancel Button (Active State Only) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_cancel"
        style="@style/Widget.SwiftShare.Button.Secondary"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/padding_screen"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:text="@string/cancel_transfer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
