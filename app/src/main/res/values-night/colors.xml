    <!-- Primary stays vibrant but slightly lighter for dark backgrounds -->
    <color name="primary">#FF768FFF</color>
    <color name="primary_dark">#FF2962FF</color>
    <color name="primary_variant">#FF2962FF</color>
    <color name="on_primary">#FF000000</color>

    <!-- Secondary -->
    <color name="secondary">#FF00E5FF</color>
    <color name="secondary_dark">#FF00B2CC</color>
    <color name="secondary_variant">#FF00BCD4</color>
    <color name="on_secondary">#FF000000</color>

    <!-- Tertiary -->
    <color name="tertiary">#FFB47CFF</color>
    <color name="on_tertiary">#FF000000</color>

    <!-- Surface Colors - Deep Indigo Dark -->
    <color name="surface">#FF121228</color>
    <color name="surface_variant">#FF1E1E3A</color>
    <color name="surface_container">#FF252548</color>
    <color name="surface_container_high">#FF2D2D56</color>
    <color name="on_surface">#FFEAEAFF</color>
