<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Theme - Same name as light theme for automatic day/night switching -->
    <style name="Theme.SwiftShare" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>

        <!-- Surface Colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>

        <!-- Status Bar - Dark, immersive -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowActivityTransitions">true</item>

        <!-- Shape -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.SwiftShare.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.SwiftShare.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.SwiftShare.LargeComponent</item>

        <!-- Bottom Navigation -->
        <item name="bottomNavigationStyle">@style/Widget.SwiftShare.BottomNavigation.Dark</item>
    </style>

    <!-- Splash Theme - Dark variant -->
    <style name="Theme.SwiftShare.Splash" parent="Theme.SwiftShare">
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <!-- Dark Bottom Navigation -->
    <style name="Widget.SwiftShare.BottomNavigation.Dark" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.SwiftShare.BottomNavigation.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">8dp</item>
    </style>
</resources>
